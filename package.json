{
  "name": "obsidian-markmap-sync",
  "version": "1.0.0",
  "description": "Bidirectional synchronization between Markdown editor and Markmap mindmap view",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "tsc": "tsc -noEmit -skipLibCheck",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "markmap",
    "mindmap",
    "markdown"
  ],
  "author": "Witt",
  "license": "MIT",
  "devDependencies": {
    "@types/d3": "7.4.3",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "6.13.0",
    "@typescript-eslint/parser": "6.13.0",
    "builtin-modules": "3.3.0",
    "esbuild": "0.19.8",
    "obsidian": "latest",
    "tslib": "2.6.2",
    "typescript": "5.3.2"
  },
  "dependencies": {
    "markmap-lib": "^0.18.12",
    "markmap-view": "^0.18.12"
  }
}
